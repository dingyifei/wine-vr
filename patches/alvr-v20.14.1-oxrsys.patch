+        assert_eq!(OXRSYS_FRAME_PACING_TIMESYNC, 0x8000);
+        assert_eq!(OXRSYS_FRAME_PACING_DISPLAY_TIMING, 0x8001);
+        assert_eq!(OXRSYS_FRAME_PACING_FRAME_TARGET, 0x8002);
+        assert_eq!(OXRSYS_FRAME_PACING_FRAME_FEEDBACK, 0x8003);
+
+        let legacy = VideoStreamingCapabilitiesLegacy {
+            default_view_resolution: UVec2::new(1832, 1920),
+            supported_refresh_rates_plus_extra_data: vec![72.0, 90.0],
+            microphone_sample_rate: 48_000,
+        };
+        let decoded = decode_video_streaming_capabilities(&legacy).unwrap();
+
+        assert_eq!(decoded.oxrsys_frame_pacing_version, 0);
+        assert_eq!(decoded.supported_refresh_rates, vec![72.0, 90.0]);
+    }
