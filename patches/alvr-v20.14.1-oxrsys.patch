+                "refresh_rate_hint": 72.0,
+                "game_audio_sample_rate": 48000,
+                "enable_foveated_encoding": false,
+                "use_multimodal_protocol": false,
+                "use_full_range": true,
+                "encoding_gamma": 1.0,
+                "enable_hdr": false,
+                "wired": false
