+use alvr_packets::{
+    OxrsysFramePacingDisplayTiming, OxrsysFramePacingFrameFeedback, OxrsysFramePacingTimesyncQuery,
+    OxrsysFramePacingTimesyncResponse, OXRSYS_FRAME_PACING_VERSION_1,
+};
+
+#[derive(Clone, Copy, Debug, Default, PartialEq, Eq)]
+pub struct FramePacingSnapshot {
+    pub supported_version: u16,
+    pub negotiated_version: u16,
+    pub session_epoch: u64,
+}
+
+pub struct ServerFramePacingState {
+    supported_version: u16,
+    negotiated_version: u16,
+    session_epoch: u64,
+    next_query_sequence: u64,
+    last_display_sequence: u64,
+    last_response_sequence: u64,
+    last_feedback_sequence: u64,
+    outstanding_queries: [Option<(u64, u64)>; 32],
+}
+
+impl ServerFramePacingState {
+    pub fn new(supported_version: u16) -> Self {
+        Self {
+            supported_version,
+            negotiated_version: 0,
+            session_epoch: 0,
+            next_query_sequence: 0,
+            last_display_sequence: 0,
+            last_response_sequence: 0,
+            last_feedback_sequence: 0,
+            outstanding_queries: [None; 32],
+        }
+    }
+
+    pub fn begin_session(
+        &mut self,
+        client_version: u16,
+        session_epoch: u64,
+    ) -> FramePacingSnapshot {
+        self.negotiated_version = if self.supported_version >= OXRSYS_FRAME_PACING_VERSION_1
+            && client_version >= OXRSYS_FRAME_PACING_VERSION_1
+            && session_epoch != 0
+        {
+            OXRSYS_FRAME_PACING_VERSION_1
+        } else {
+            0
+        };
+        self.session_epoch = if self.negotiated_version == OXRSYS_FRAME_PACING_VERSION_1 {
+            session_epoch
+        } else {
+            0
+        };
+        self.next_query_sequence = 0;
+        self.last_display_sequence = 0;
+        self.last_response_sequence = 0;
+        self.last_feedback_sequence = 0;
+        self.outstanding_queries = [None; 32];
+        self.snapshot()
+    }
+
+    pub fn end_session(&mut self, session_epoch: u64) {
+        if self.session_epoch == session_epoch {
+            self.negotiated_version = 0;
+            self.session_epoch = 0;
+            self.next_query_sequence = 0;
+            self.last_display_sequence = 0;
+            self.last_response_sequence = 0;
+            self.last_feedback_sequence = 0;
+            self.outstanding_queries = [None; 32];
+        }
+    }
+
+    pub fn snapshot(&self) -> FramePacingSnapshot {
+        FramePacingSnapshot {
+            supported_version: self.supported_version,
+            negotiated_version: self.negotiated_version,
+            session_epoch: self.session_epoch,
+        }
+    }
+
+    pub fn next_timesync_query(
+        &mut self,
+        server_send_time_ns: u64,
+    ) -> Option<OxrsysFramePacingTimesyncQuery> {
+        if self.negotiated_version != OXRSYS_FRAME_PACING_VERSION_1 {
+            return None;
+        }
+        self.next_query_sequence = self.next_query_sequence.wrapping_add(1).max(1);
+        let sequence = self.next_query_sequence;
+        self.outstanding_queries[sequence as usize % self.outstanding_queries.len()] =
+            Some((sequence, server_send_time_ns));
+        Some(OxrsysFramePacingTimesyncQuery {
+            session_epoch: self.session_epoch,
+            query_sequence: sequence,
+            server_send_time_ns,
+        })
+    }
+
+    pub fn accept_display_timing(&mut self, packet: &OxrsysFramePacingDisplayTiming) -> bool {
+        if !self.accept_sequence(
+            packet.session_epoch,
+            packet.display_sequence,
+            self.last_display_sequence,
+        ) || packet.predicted_display_time_ns == 0
+            || packet.predicted_display_period_ns == 0
+        {
+            return false;
+        }
+        self.last_display_sequence = packet.display_sequence;
+        true
+    }
+
+    pub fn accept_timesync_response(&mut self, packet: &OxrsysFramePacingTimesyncResponse) -> bool {
+        if !self.accept_sequence(
+            packet.session_epoch,
+            packet.query_sequence,
+            self.last_response_sequence,
+        ) || packet.server_send_time_ns == 0
+            || packet.client_receive_time_ns == 0
+            || packet.client_send_time_ns < packet.client_receive_time_ns
+        {
+            return false;
+        }
+
+        let slot = packet.query_sequence as usize % self.outstanding_queries.len();
+        if self.outstanding_queries[slot]
+            != Some((packet.query_sequence, packet.server_send_time_ns))
+        {
+            return false;
+        }
+        self.outstanding_queries[slot] = None;
+        self.last_response_sequence = packet.query_sequence;
+        true
+    }
+
+    pub fn accept_frame_feedback(&mut self, packet: &OxrsysFramePacingFrameFeedback) -> bool {
+        if !self.accept_sequence(
+            packet.session_epoch,
+            packet.feedback_sequence,
+            self.last_feedback_sequence,
+        ) || packet.frame_timestamp_ns == 0
+            || packet.predicted_display_time_ns == 0
+            || packet.times_displayed == 0
+        {
+            return false;
+        }
+        self.last_feedback_sequence = packet.feedback_sequence;
+        true
+    }
+
+    fn accept_sequence(&self, epoch: u64, sequence: u64, last_sequence: u64) -> bool {
+        self.negotiated_version == OXRSYS_FRAME_PACING_VERSION_1
+            && epoch == self.session_epoch
+            && sequence > last_sequence
+    }
+}
