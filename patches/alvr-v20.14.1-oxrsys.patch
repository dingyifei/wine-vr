+    fn version_zero_and_reconnect_reset_fail_closed() {
+        let mut state = ServerFramePacingState::new(1);
+        assert_eq!(state.begin_session(0, 1).negotiated_version, 0);
+        assert!(state.next_timesync_query(10).is_none());
+
+        assert_eq!(state.begin_session(1, 7).negotiated_version, 1);
+        let query = state.next_timesync_query(10).unwrap();
+        assert_eq!(query.query_sequence, 1);
+        state.end_session(6);
+        assert_eq!(state.snapshot().session_epoch, 7);
+        state.end_session(7);
+        assert_eq!(state.snapshot().negotiated_version, 0);
+
+        assert_eq!(state.begin_session(1, 8).session_epoch, 8);
+        assert_eq!(state.next_timesync_query(20).unwrap().query_sequence, 1);
+    }
+
