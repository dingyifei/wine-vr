new file mode 100644
index 00000000..32f51620
--- /dev/null
+++ b/alvr/client_core/src/frame_pacing.rs
@@ -0,0 +1,454 @@
+use alvr_common::once_cell::sync::Lazy;
+use alvr_packets::{OxrsysFramePacingFrameTarget, OXRSYS_FRAME_PACING_VERSION_1};
+use std::{
+    collections::VecDeque,
+    sync::mpsc::{SyncSender, TrySendError},
+    time::Instant,
+};
+
+const CLOCK_MAPPING_MAX_AGE_NS: u64 = 1_000_000_000;
+const CLOCK_MAPPING_MAX_DELTA_NS: i128 = 5_000_000_000;
+const ACQUIRE_ALLOWANCE_CUT_GUARD_NS: u64 = 2_000_000;
+const ACQUIRE_ALLOWANCE_GROW_NS: u64 = 10_000;
+const ACQUIRE_ALLOWANCE_MINIMUM_NS: u64 = 1_000_000;
+
+static CLIENT_CLOCK_ORIGIN: Lazy<Instant> = Lazy::new(Instant::now);
+
+/// Monotonic nanoseconds in the clock domain used by the pacing connection threads.
+pub fn client_monotonic_now_ns() -> u64 {
+    CLIENT_CLOCK_ORIGIN
+        .elapsed()
+        .as_nanos()
+        .min(u64::MAX as u128) as u64
+}
+
+pub(crate) fn try_send_bounded<T>(sender: &SyncSender<T>, value: T) -> bool {
+    match sender.try_send(value) {
+        Ok(()) => true,
+        Err(TrySendError::Full(_)) | Err(TrySendError::Disconnected(_)) => false,
+    }
+}
+
+/// Explicitly maps OpenXR XrTime into the monotonic clock used by the networking threads.
+#[derive(Clone, Copy, Debug, Default)]
+pub struct FramePacingClockMapper {
+    sample: Option<ClockSample>,
+}
+
+#[derive(Clone, Copy, Debug)]
+struct ClockSample {
+    xr_time_ns: i64,
+    client_time_ns: u64,
+}
+
+impl FramePacingClockMapper {
+    pub fn reset(&mut self) {
+        self.sample = None;
+    }
+
+    /// Updates the mapping from a near-simultaneous xrInstance.now()/Instant sample pair.
+    /// Backward samples are rejected rather than moving the display timeline backward.
+    pub fn update(&mut self, xr_time_ns: i64, client_time_ns: u64) -> bool {
+        if xr_time_ns <= 0 {
+            return false;
+        }
+
+        if self.sample.is_some_and(|sample| {
+            xr_time_ns < sample.xr_time_ns || client_time_ns < sample.client_time_ns
+        }) {
+            return false;
+        }
+
+        self.sample = Some(ClockSample {
+            xr_time_ns,
+            client_time_ns,
+        });
+        true
+    }
+
+    /// Maps one XrTime to client monotonic nanoseconds. Old mappings and implausibly distant
+    /// timestamps fail closed so ambiguous clock data cannot influence pacing.
+    pub fn map_xr_time(&self, xr_time_ns: i64, client_now_ns: u64) -> Option<u64> {
+        let sample = self.sample?;
+        if xr_time_ns <= 0
+            || client_now_ns < sample.client_time_ns
+            || client_now_ns - sample.client_time_ns > CLOCK_MAPPING_MAX_AGE_NS
+        {
+            return None;
+        }
+
+        let delta_ns = xr_time_ns as i128 - sample.xr_time_ns as i128;
+        if delta_ns.abs() > CLOCK_MAPPING_MAX_DELTA_NS {
+            return None;
+        }
+
+        u64::try_from(sample.client_time_ns as i128 + delta_ns).ok()
+    }
+}
+
+#[derive(Clone, Copy, Debug, Default, PartialEq, Eq)]
+pub struct FrameTimingMetadata {
+    pub session_epoch: u64,
+    pub target_sequence: u64,
+    pub frame_timestamp_ns: u64,
+    pub display_target_time_ns: u64,
+    pub decode_complete_time_ns: u64,
+}
+
+/// Bounded frame metadata ring shared by target receipt, decoder completion and the XR latch.
+pub struct FrameMetadataRing {
+    capacity: usize,
+    negotiated_version: u16,
+    session_epoch: u64,
+    last_target_sequence: u64,
+    entries: VecDeque<FrameTimingMetadata>,
+}
+
+impl Default for FrameMetadataRing {
+    fn default() -> Self {
+        Self::new(64)
+    }
+}
+
+impl FrameMetadataRing {
+    pub fn new(capacity: usize) -> Self {
+        Self {
+            capacity: capacity.max(1),
+            negotiated_version: 0,
+            session_epoch: 0,
+            last_target_sequence: 0,
+            entries: VecDeque::with_capacity(capacity.max(1)),
+        }
+    }
+
+    pub fn reset(&mut self, negotiated_version: u16, session_epoch: u64) {
+        self.negotiated_version = negotiated_version;
+        self.session_epoch = session_epoch;
+        self.last_target_sequence = 0;
+        self.entries.clear();
+    }
+
+    pub fn len(&self) -> usize {
+        self.entries.len()
+    }
+
+    pub fn record_target(&mut self, target: OxrsysFramePacingFrameTarget) -> bool {
+        if self.negotiated_version != OXRSYS_FRAME_PACING_VERSION_1
+            || target.session_epoch != self.session_epoch
+            || target.target_sequence <= self.last_target_sequence
+            || target.frame_timestamp_ns == 0
+            || target.display_target_time_ns == 0
+        {
+            return false;
+        }
+        self.last_target_sequence = target.target_sequence;
+
+        if let Some(entry) = self
+            .entries
+            .iter_mut()
+            .find(|entry| entry.frame_timestamp_ns == target.frame_timestamp_ns)
+        {
+            entry.target_sequence = target.target_sequence;
+            entry.display_target_time_ns = target.display_target_time_ns;
+            return true;
+        }
+
+        self.push(FrameTimingMetadata {
+            session_epoch: target.session_epoch,
+            target_sequence: target.target_sequence,
+            frame_timestamp_ns: target.frame_timestamp_ns,
+            display_target_time_ns: target.display_target_time_ns,
+            decode_complete_time_ns: 0,
+        });
+        true
+    }
+
+    pub fn record_decode_complete(
+        &mut self,
+        frame_timestamp_ns: u64,
+        decode_complete_time_ns: u64,
+    ) -> bool {
+        if self.negotiated_version != OXRSYS_FRAME_PACING_VERSION_1
+            || self.session_epoch == 0
+            || frame_timestamp_ns == 0
+            || decode_complete_time_ns == 0
+        {
+            return false;
+        }
+
+        if let Some(entry) = self
+            .entries
+            .iter_mut()
+            .find(|entry| entry.frame_timestamp_ns == frame_timestamp_ns)
+        {
+            entry.decode_complete_time_ns = decode_complete_time_ns;
+            return true;
+        }
+
+        self.push(FrameTimingMetadata {
+            session_epoch: self.session_epoch,
+            target_sequence: 0,
+            frame_timestamp_ns,
+            display_target_time_ns: 0,
+            decode_complete_time_ns,
+        });
+        true
+    }
+
+    pub fn get(&self, frame_timestamp_ns: u64) -> Option<FrameTimingMetadata> {
+        self.entries
+            .iter()
+            .find(|entry| {
+                entry.session_epoch == self.session_epoch
+                    && entry.frame_timestamp_ns == frame_timestamp_ns
+            })
+            .copied()
+    }
+
+    fn push(&mut self, entry: FrameTimingMetadata) {
+        while self.entries.len() >= self.capacity {
+            self.entries.pop_front();
+        }
+        self.entries.push_back(entry);
+    }
+}
+
+/// Selects the newest decoded frame due for this display slot. Untargeted frames are only due at
+/// the queue front, so raced/missing metadata cannot evict a targeted future frame.
+pub fn select_frame_for_display(
+    frame_timestamps_ns: &[u64],
+    display_time_ns: u64,
+    display_period_ns: u64,
+    mut target_for_frame: impl FnMut(u64) -> Option<u64>,
+) -> Option<usize> {
+    let mut due_index = None;
+    for (index, timestamp_ns) in frame_timestamps_ns.iter().copied().enumerate() {
+        let target_ns = target_for_frame(timestamp_ns).unwrap_or(0);
+        let due = if target_ns == 0 || display_period_ns == 0 {
+            index == 0
+        } else {
+            target_ns <= display_time_ns.saturating_add(display_period_ns / 2)
+        };
+        if due {
+            due_index = Some(index);
+        }
+    }
+    due_index
+}
+
+/// Adaptive per-vsync acquire deadline and intended-slot slack attribution.
+#[derive(Clone, Copy, Debug)]
+pub struct AcquireDeadlineController {
+    allowance_ns: u64,
+    pending_missed: Option<(u64, u64)>,
+}
+
+impl AcquireDeadlineController {
+    pub fn new(display_period_ns: u64) -> Self {
+        Self {
+            allowance_ns: (display_period_ns / 2).max(ACQUIRE_ALLOWANCE_MINIMUM_NS),
+            pending_missed: None,
+        }
+    }
+
+    pub fn reset(&mut self, display_period_ns: u64) {
+        *self = Self::new(display_period_ns);
+    }
+
+    pub fn allowance_ns(&self) -> u64 {
+        self.allowance_ns
+    }
+
+    pub fn deadline_ns(&self, frame_loop_start_ns: u64) -> u64 {
+        frame_loop_start_ns.saturating_add(self.allowance_ns)
+    }
+
+    pub fn record_missed_slot(&mut self, deadline_ns: u64, predicted_display_time_ns: u64) {
+        self.pending_missed
+            .get_or_insert((deadline_ns, predicted_display_time_ns));
+    }
+
+    /// Returns slack and whether the intended-slot attribution is unambiguous.
+    pub fn complete_acquire(
+        &mut self,
+        decode_complete_time_ns: u64,
+        display_target_time_ns: u64,
+        current_deadline_ns: u64,
+        current_display_time_ns: u64,
+        display_period_ns: u64,
+    ) -> (i64, bool) {
+        if decode_complete_time_ns == 0 {
+            self.pending_missed = None;
+            return (0, false);
+        }
+
+        let (deadline_ns, deadline_display_ns) = self
+            .pending_missed
+            .filter(|(deadline_ns, _)| decode_complete_time_ns > *deadline_ns)
+            .unwrap_or((current_deadline_ns, current_display_time_ns));
+        self.pending_missed = None;
+
+        let mut slack_ns = deadline_ns as i128 - decode_complete_time_ns as i128;
+        if display_target_time_ns == 0 || deadline_display_ns == 0 || display_period_ns == 0 {
+            return (clamp_i128_to_i64(slack_ns), false);
+        }
+
+        let slot_shift = (display_target_time_ns as i128 - deadline_display_ns as i128) as f64
+            / display_period_ns as f64;
+        let nearest_slot_shift = slot_shift.round();
+        if (slot_shift - nearest_slot_shift).abs() > 0.35 {
+            return (clamp_i128_to_i64(slack_ns), false);
+        }
+
+        slack_ns += nearest_slot_shift as i128 * display_period_ns as i128;
+        (clamp_i128_to_i64(slack_ns), true)
+    }
+
+    pub fn update_after_submit(&mut self, frame_elapsed_ns: u64, display_period_ns: u64) {
+        if display_period_ns == 0 {
+            return;
+        }
+
+        if frame_elapsed_ns > display_period_ns {
+            self.allowance_ns = self.allowance_ns.saturating_sub(
+                frame_elapsed_ns - display_period_ns + ACQUIRE_ALLOWANCE_CUT_GUARD_NS,
+            );
+        } else {
+            self.allowance_ns = self.allowance_ns.saturating_add(ACQUIRE_ALLOWANCE_GROW_NS);
+        }
+        self.allowance_ns = self
+            .allowance_ns
+            .clamp(ACQUIRE_ALLOWANCE_MINIMUM_NS, display_period_ns);
+    }
+}
+
+fn clamp_i128_to_i64(value: i128) -> i64 {
+    value.clamp(i64::MIN as i128, i64::MAX as i128) as i64
+}
