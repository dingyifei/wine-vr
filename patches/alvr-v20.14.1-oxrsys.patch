+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    fn target(
+        epoch: u64,
+        sequence: u64,
+        timestamp: u64,
+        display: u64,
+    ) -> OxrsysFramePacingFrameTarget {
+        OxrsysFramePacingFrameTarget {
+            session_epoch: epoch,
+            target_sequence: sequence,
+            frame_timestamp_ns: timestamp,
+            display_target_time_ns: display,
+        }
+    }
+
+    #[test]
+    fn xr_clock_mapping_rejects_stale_and_backward_samples() {
+        let mut mapper = FramePacingClockMapper::default();
+        assert!(mapper.update(10_000, 1_000));
+        assert_eq!(mapper.map_xr_time(10_500, 1_100), Some(1_500));
+        assert_eq!(
+            mapper.map_xr_time(10_500, 1_000 + CLOCK_MAPPING_MAX_AGE_NS + 1),
+            None
+        );
+        assert!(!mapper.update(9_999, 1_200));
+        assert!(!mapper.update(10_100, 999));
+    }
+
+    #[test]
+    fn metadata_ring_handles_target_decode_races_and_reconnects() {
+        let mut ring = FrameMetadataRing::new(4);
+        ring.reset(1, 7);
+
+        assert!(ring.record_decode_complete(100, 1_000));
+        assert!(ring.record_target(target(7, 1, 100, 20_000)));
+        assert_eq!(ring.get(100).unwrap().decode_complete_time_ns, 1_000);
+        assert_eq!(ring.get(100).unwrap().display_target_time_ns, 20_000);
+
+        assert!(ring.record_target(target(7, 2, 200, 30_000)));
+        assert!(ring.record_decode_complete(200, 2_000));
+        assert_eq!(ring.get(200).unwrap().decode_complete_time_ns, 2_000);
+        assert!(!ring.record_target(target(7, 2, 300, 40_000)));
+
+        ring.reset(1, 8);
+        assert!(ring.get(100).is_none());
+        assert!(!ring.record_target(target(7, 3, 300, 40_000)));
+        assert!(ring.record_target(target(8, 1, 300, 40_000)));
+    }
+
+    #[test]
+    fn metadata_ring_is_bounded() {
+        let mut ring = FrameMetadataRing::new(3);
+        ring.reset(1, 1);
+        for sequence in 1..=8 {
+            assert!(ring.record_target(target(1, sequence, sequence, 1_000 + sequence)));
+        }
+        assert_eq!(ring.len(), 3);
+        assert!(ring.get(5).is_none());
+        assert!(ring.get(8).is_some());
+    }
+
+    #[test]
+    fn target_aware_latch_holds_future_frames_and_selects_latest_due() {
+        let frames = [10, 20, 30];
+        let selected = select_frame_for_display(&frames, 1_000, 100, |timestamp| match timestamp {
+            10 => Some(900),
+            20 => Some(1_040),
+            30 => Some(1_200),
+            _ => None,
+        });
+        assert_eq!(selected, Some(1));
+
+        let selected = select_frame_for_display(&frames, 1_000, 100, |_| Some(1_200));
+        assert_eq!(selected, None);
+        let selected = select_frame_for_display(&frames, 1_000, 100, |_| None);
+        assert_eq!(selected, Some(0));
+    }
+
+    #[test]
+    fn missed_deadline_reports_negative_rebased_slack() {
+        let mut controller = AcquireDeadlineController::new(10_000_000);
+        controller.record_missed_slot(5_000_000, 100_000_000);
+        let (slack, valid) = controller.complete_acquire(
+            6_000_000,
+            100_000_000,
+            15_000_000,
+            110_000_000,
+            10_000_000,
+        );
+        assert!(valid);
+        assert_eq!(slack, -1_000_000);
+    }
+
+    #[test]
+    fn ambiguous_slot_does_not_produce_valid_slack() {
+        let mut controller = AcquireDeadlineController::new(10_000_000);
+        let (_, valid) =
+            controller.complete_acquire(4_000_000, 104_000_000, 5_000_000, 100_000_000, 10_000_000);
+        assert!(!valid);
+    }
+
+    #[test]
+    fn adaptive_deadline_is_bounded_after_overrun() {
+        let mut controller = AcquireDeadlineController::new(10_000_000);
+        controller.update_after_submit(15_000_000, 10_000_000);
+        assert_eq!(controller.allowance_ns(), ACQUIRE_ALLOWANCE_MINIMUM_NS);
+        controller.update_after_submit(9_000_000, 10_000_000);
+        assert_eq!(
+            controller.allowance_ns(),
+            ACQUIRE_ALLOWANCE_MINIMUM_NS + ACQUIRE_ALLOWANCE_GROW_NS
+        );
+    }
+
+    #[test]
+    fn bounded_feedback_queue_never_waits_when_full() {
+        let (sender, receiver) = std::sync::mpsc::sync_channel(1);
+        assert!(try_send_bounded(&sender, 1));
+        assert!(!try_send_bounded(&sender, 2));
+        assert_eq!(receiver.try_recv(), Ok(1));
+        drop(receiver);
+        assert!(!try_send_bounded(&sender, 3));
+    }
+}
